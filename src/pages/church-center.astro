---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Church Center | Irving College Baptist Church">
  <section class="church-center-hero">
    <div class="church-center-hero-content">
      <p class="section-eyebrow">Stay Connected</p>

      <h1>Your Church. All Week Long.</h1>

      <p>
        Church Center makes it easy to connect with Irving College Baptist
        Church, register for events, give online, find a group, check in your
        family, and take your next step.
      </p>

      <a
        href="https://irvingcollege.churchcenter.com"
        target="_blank"
        rel="noopener noreferrer"
        class="primary-button"
      >
        Open Church Center
      </a>
    </div>
  </section>

  <section class="church-center-options">
    <div class="church-center-container">
      <div class="section-heading">
        <p class="section-eyebrow">Everything in One Place</p>
        <h2>What Can You Do in Church Center?</h2>

        <p>
          Choose an option below to get connected with what is happening at
          Irving College Baptist Church.
        </p>
      </div>

      <div class="church-center-grid">
        <article class="church-center-card">
          <div class="church-center-icon" aria-hidden="true">♡</div>

          <h3>Give Online</h3>

          <p>
            Make a secure gift, manage recurring donations, and view your
            giving history.
          </p>

          <a
            href="https://irvingcollege.churchcenter.com/giving"
            target="_blank"
            rel="noopener noreferrer"
          >
            Give Online →
          </a>
        </article>

        <article class="church-center-card">
          <div class="church-center-icon" aria-hidden="true">◫</div>

          <h3>Upcoming Events</h3>

          <p>
            See what is coming up and find opportunities to worship, connect,
            grow, and serve.
          </p>

          <a
            href="https://irvingcollege.churchcenter.com/calendar"
            target="_blank"
            rel="noopener noreferrer"
          >
            View Calendar →
          </a>
        </article>

        <article class="church-center-card">
          <div class="church-center-icon" aria-hidden="true">✓</div>

          <h3>Event Registration</h3>

          <p>
            Register yourself or your family for upcoming church events,
            activities, and special opportunities.
          </p>

          <a
            href="https://irvingcollege.churchcenter.com/registrations"
            target="_blank"
            rel="noopener noreferrer"
          >
            View Registrations →
          </a>
        </article>

        <article class="church-center-card">
          <div class="church-center-icon" aria-hidden="true">◎</div>

          <h3>Find a Group</h3>

          <p>
            Discover a group where you can build relationships, study the
            Bible, and grow in your faith.
          </p>

          <a
            href="https://irvingcollege.churchcenter.com/groups"
            target="_blank"
            rel="noopener noreferrer"
          >
            Explore Groups →
          </a>
        </article>

        <article class="church-center-card">
          <div class="church-center-icon" aria-hidden="true">◇</div>

          <h3>Prayer and Next Steps</h3>

          <p>
            Share a prayer request, ask a question, or let us know how you
            would like to get connected.
          </p>

          <a
            href="https://irvingcollege.churchcenter.com"
            target="_blank"
            rel="noopener noreferrer"
          >
            View Church Center →
          </a>
        </article>

        <article class="church-center-card">
          <div class="church-center-icon" aria-hidden="true">⌂</div>

          <h3>Family Check-In</h3>

          <p>
            Use the Church Center app to begin checking in your household
            before arriving at church.
          </p>

          <a
            href="https://irvingcollege.churchcenter.com"
            target="_blank"
            rel="noopener noreferrer"
          >
            Open Church Center →
          </a>
        </article>
      </div>
    </div>
  </section>

  <section class="church-center-app">
    <div class="church-center-app-content">
      <div>
        <p class="section-eyebrow">Take It With You</p>

        <h2>Download the Church Center App</h2>

        <p>
          Access your registrations, giving, groups, household information,
          and family check-in from your phone throughout the week.
        </p>
      </div>

      <a
        href="https://irvingcollege.churchcenter.com"
        target="_blank"
        rel="noopener noreferrer"
        class="primary-button"
      >
        Get Started
      </a>
    </div>
  </section>
</BaseLayout>