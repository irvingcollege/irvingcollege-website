---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Plan Your Visit | Irving College Baptist Church">

<section class="page-hero">
  <div class="container">
    <p class="section-eyebrow">First Time Here?</p>

    <h1>Plan Your Visit</h1>

    <p>
      We'd love to help make your first visit to Irving College Baptist Church
      a great experience.
    </p>
  </div>
</section>

<section class="container visit-intro">

  <h2>We're Excited to Meet You</h2>

  <p>
    Whether you've been attending church your whole life or you're simply
    exploring faith, you'll find a welcoming church family here.
  </p>

</section>
<section class="visit-section">
  <div class="container">

    <div class="section-heading">
      <p class="section-eyebrow">Your First Visit</p>
      <h2>What to Expect</h2>
      <p>
        We want your first visit to be comfortable, encouraging, and focused
        on helping you connect with God and others.
      </p>
    </div>

    <div class="expect-grid">

      <article class="expect-card">
        <div class="expect-icon">😊</div>
        <h3>Friendly People</h3>
        <p>
          You'll be welcomed warmly, but never pressured or singled out.
        </p>
      </article>

      <article class="expect-card">
        <div class="expect-icon">📖</div>
        <h3>Biblical Preaching</h3>
        <p>
          Every message is centered on God's Word and practical for everyday
          life.
        </p>
      </article>

      <article class="expect-card">
        <div class="expect-icon">🎵</div>
        <h3>Christ-Centered Worship</h3>
        <p>
          We worship together through music that points our hearts toward
          Jesus.
        </p>
      </article>

      <article class="expect-card">
        <div class="expect-icon">👶</div>
        <h3>Nursery Available</h3>
        <p>
          Loving, safe nursery care is available during every service.
        </p>
      </article>

      <article class="expect-card">
        <div class="expect-icon">👕</div>
        <h3>Come As You Are</h3>
        <p>
          Some people dress up, others dress casually. You'll fit in either
          way.
        </p>
      </article>

      <article class="expect-card">
        <div class="expect-icon">☕</div>
        <h3>Stay & Connect</h3>
        <p>
          We'd love to answer your questions and help you get connected after
          the service.
        </p>
      </article>

    </div>

  </div>
</section>
<section class="families-section">
  <div class="container">

    <div class="families-content">

      <div>
        <p class="section-eyebrow">Families Matter</p>

        <h2>Your Children Are Important to Us</h2>

        <p>
          We know visiting a church with children can feel overwhelming.
          Our goal is to provide a safe, loving environment where kids can
          learn about Jesus while parents worship with confidence.
        </p>

        <ul class="family-list">
          <li>👶 Nursery available during every service</li>
          <li>📚 Age-appropriate Bible classes</li>
          <li>🧒 Friendly, caring volunteers</li>
          <li>❤️ A growing Special Needs Ministry</li>
        </ul>

      </div>

      <div class="family-card">

        <h3>Questions?</h3>

        <p>
          We'd be happy to answer any questions before your visit.
        </p>

        <a href="/contact" class="primary-button">
          Contact Us
        </a>

      </div>

    </div>

  </div>
</section>
<section class="pastor-section">
  <div class="container">

    <div class="pastor-grid">

      <div class="pastor-photo">
        <img
          src="/images/pastor-ryan.jpg"
          alt="Pastor Ryan"
        />
      </div>

      <div class="pastor-content">

        <p class="section-eyebrow">Meet Our Pastor</p>

        <h2>A Personal Welcome</h2>

        <p>
          Thank you for considering a visit to Irving College Baptist Church.
          Whether you're looking for a church home, exploring faith, or simply
          have questions, we'd love the opportunity to meet you.
        </p>

        <p>
          Our desire is to help people know Jesus, grow in their faith, and
          become part of a loving church family. We hope to meet you soon!
        </p>

        <p class="pastor-signature">
          — Pastor Ryan
        </p>

      </div>

    </div>

  </div>
</section>
<section class="location-section">
  <div class="container">

    <div class="section-heading">
      <p class="section-eyebrow">Find Us</p>
      <h2>We'd Love to Meet You</h2>
      <p>
        We'd love to welcome you this Sunday. If you have trouble finding us,
        feel free to give us a call.
      </p>
    </div>

    <div class="location-grid">

      <div class="location-info">

        <h3>Irving College Baptist Church</h3>

        <p>
          15431 Beersheba Highway<br>
          McMinnville, TN 37110
        </p>

        <p>
          Sunday School – 9:30 AM<br>
          Worship – 10:30 AM
        </p>

        <a
          class="primary-button"
          href="https://maps.google.com/?q=15431+Beersheba+Highway+McMinnville+TN+37110"
          target="_blank"
          rel="noopener noreferrer"
        >
          Get Directions
        </a>

      </div>

      <div class="map-container">
        <iframe
          src="https://www.google.com/maps?q=15431+Beersheba+Highway+McMinnville+TN+37110&output=embed"
          loading="lazy"
          allowfullscreen
          referrerpolicy="no-referrer-when-downgrade">
        </iframe>
      </div>

    </div>

  </div>
</section>
<section class="faq-section">
  <div class="container">

    <div class="section-heading">
      <p class="section-eyebrow">Questions?</p>
      <h2>Frequently Asked Questions</h2>
    </div>

    <details>
      <summary>What should I wear?</summary>
      <p>Some people dress up while others dress casually. Wear what makes you comfortable.</p>
    </details>

    <details>
      <summary>How long is the service?</summary>
      <p>Our Sunday morning worship service lasts about one hour.</p>
    </details>

    <details>
      <summary>Is nursery available?</summary>
      <p>Yes! We provide a safe, loving nursery during every service.</p>
    </details>

    <details>
      <summary>Where do I park?</summary>
      <p>Guest parking is available close to the main entrance, and our team will be happy to help you find your way.</p>
    </details>

  </div>
</section>
</BaseLayout>