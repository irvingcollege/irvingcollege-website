---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="About Us | Irving College Baptist Church">

<section class="about-hero">
  <div class="container">

    <p class="section-eyebrow">About Us</p>

    <h1>A Place of Hope for Warren County</h1>

    <p class="hero-description">
      Irving College Baptist Church exists to help people know Jesus,
      grow in their faith, and share His love with our community.
      Whether you've attended church your whole life or you're just
      beginning to ask questions, you'll find a place to belong here.
    </p>

  </div>
</section>
<section class="our-story">
  <div class="container">

    <div class="story-grid">

      <div class="story-image">
        <img src="/images/church-family.jpg" alt="Irving College Baptist Church congregation">
      </div>

      <div class="story-content">

        <p class="section-eyebrow">Our Story</p>

        <h2>Serving Our Community Since 1980</h2>

        <p>
          Since 1980, Irving College Baptist Church has been committed to
          faithfully sharing the Gospel of Jesus Christ while serving families
          throughout Warren County and the surrounding communities.
        </p>

        <p>
          Over the years, God has blessed our church with opportunities to
          disciple believers, support missionaries, care for children and
          families, and become a place where people can find hope through
          Christ.
        </p>

        <p>
          While our methods have grown and changed through the years, our
          message has never changed. We remain committed to teaching God's
          Word, worshiping Jesus Christ, loving our neighbors, and helping
          people take their next step of faith.
        </p>

      </div>

    </div>

  </div>
</section>
<section class="mission-section">
  <div class="container">

    <div class="section-heading">
      <p class="section-eyebrow">Our Mission</p>

      <h2>Helping People Take Their Next Step with Jesus</h2>

      <p>
        Everything we do at Irving College Baptist Church is centered around
        helping people know Christ, grow in their faith, love others, and share
        the hope of the Gospel.
      </p>
    </div>

    <div class="mission-grid">

      <div class="mission-card">
        <div class="mission-icon">✝️</div>
        <h3>Know Christ</h3>
        <p>
          We believe a relationship with Jesus Christ changes everything.
          Our greatest desire is for every person to know Him personally.
        </p>
      </div>

      <div class="mission-card">
        <div class="mission-icon">📖</div>
        <h3>Grow in Faith</h3>
        <p>
          Through biblical preaching, Bible study, and discipleship,
          we help believers grow into mature followers of Christ.
        </p>
      </div>

      <div class="mission-card">
        <div class="mission-icon">❤️</div>
        <h3>Love People</h3>
        <p>
          We strive to create a church where every person feels welcomed,
          valued, and encouraged as part of God's family.
        </p>
      </div>

      <div class="mission-card">
        <div class="mission-icon">🌎</div>
        <h3>Share Hope</h3>
        <p>
          From Warren County to the ends of the earth, we are committed
          to sharing the life-changing message of Jesus Christ.
        </p>
      </div>

    </div>

  </div>
</section>
<section class="beliefs-section">
  <div class="container">

    <div class="section-heading">
      <p class="section-eyebrow">What We Believe</p>

      <h2>Built on the Truth of God's Word</h2>

      <p>
        Our beliefs shape everything we do. While we encourage questions and
        conversations, these biblical convictions guide our ministry and our
        mission.
      </p>
    </div>

    <div class="beliefs-grid">

      <div class="belief-card">
        <h3>📖 The Bible</h3>
        <p>
          We believe the Bible is God's inspired, trustworthy, and authoritative
          Word for every generation.
        </p>
      </div>

      <div class="belief-card">
        <h3>✝️ Jesus Christ</h3>
        <p>
          We believe Jesus is the Son of God who lived a sinless life, died for
          our sins, rose again, and is the only way to salvation.
        </p>
      </div>

      <div class="belief-card">
        <h3>❤️ Salvation</h3>
        <p>
          Salvation is a gift of God's grace received through faith in Jesus
          Christ—not something we earn through good works.
        </p>
      </div>

      <div class="belief-card">
        <h3>🌍 Our Mission</h3>
        <p>
          Jesus has called His church to make disciples, serve others, and share
          the Gospel with our community and around the world.
        </p>
      </div>

    </div>

    <div class="beliefs-button">
    <a href="/plan-your-visit" class="primary-button">
  We'd Love to Meet You
</a>
    </div>

  </div>
</section>
</BaseLayout>